# consulta connection config. Copy to .env (gitignored) and fill in.
# Process-environment variables override these. With --profile NAME, a
# NAME_-prefixed key (e.g. QA_DB_HOST) wins over the bare key.

DB_BACKEND=oracle
DB_HOST=
DB_PORT=
DB_SERVICE=
DB_USER=
DB_PASSWORD=
DB_FETCH_LIMIT=1000

# Extra profiles in the same file, selected with --profile qa / --profile tst:
# QA_DB_HOST=
# QA_DB_PORT=
# QA_DB_SERVICE=
# QA_DB_USER=
# QA_DB_PASSWORD=

# Future MSSQL backend (door open; install with: uv sync --extra mssql):
# DB_BACKEND=mssql
# DB_HOST=analytics-prd.example.edu
# DB_PORT=1433
# DB_DATABASE=SomeDatabase
# DB_USER=
# DB_PASSWORD=

# Or bypass the discrete keys entirely with a full SQLAlchemy URL:
# DATABASE_URL=oracle+oracledb://user:pass@host:1521/?service_name=PRD
